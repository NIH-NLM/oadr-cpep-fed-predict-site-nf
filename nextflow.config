params {
    // Inputs (provided at runtime)
    data               = null          // this site's data CSV (features + target)
    site               = null          // this institution's identifier, e.g. SDY524
    consensus_features = null          // null -> Phase 1 (select); path -> Phase 2 (fit)

    // Output
    outdir       = "results"
    publish_mode = "copy"

    // Model / reproducibility
    target      = "log_auc"
    seed        = 42
    ridge_alpha = 1.0
    lasso_alpha = 0.008
    n_trees     = 200

    // Shared container (built from container/oadr-cpep/, published to a registry)
    container = "ghcr.io/nih-nlm/oadr-cpep:0.1.0"
}

docker {
    enabled = true
}

process {
    withLabel: oadr_cpep {
        container = params.container
    }
}
