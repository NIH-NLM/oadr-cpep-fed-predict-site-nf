params {
    // Inputs (provided at runtime) — the artifact you pass selects the phase
    site                   = null      // the study id, e.g. SDY524
    panel                  = "B"       // feature panel: A (legacy 9) or B (extended 12)
    data_files             = null      // glob of the flat data files, e.g. 's3://bucket/data/*'
    consensus_features     = null      // path -> Phase 2 (fit on this feature-list CSV)
    federated_coefficients = null      // glob of federated_* results -> Phase 3 (apply)
    from                   = null      // feature-source tag to scope Phase 3 (e.g. SDY524)

    // Output
    outdir       = "results"
    publish_mode = "copy"

    // Model / reproducibility
    seed        = 42
    ridge_alpha = 1.0
    lasso_alpha = 0.008
    n_trees     = 200
    n_boot      = 2000     // bootstrap resamples for the R² 95% CI

    // Shared container — built & published from the oadr-cpep package repo
    container = "ghcr.io/nih-nlm/oadr-cpep:latest"
}

docker {
    enabled = true
}

process {
    withLabel: oadr_cpep {
        container = params.container
    }
}
