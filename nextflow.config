params {
    // Inputs (provided at runtime) — the artifact you pass selects the phase
    site                   = null      // the study id, e.g. SDY524
    panel                  = "B"       // feature panel: A (legacy 9) or B (extended 12)
    data_root              = null      // path to the oadr-autoantibody data/ tree
    consensus_features     = null      // path -> Phase 2 (fit on consensus features)
    federated_coefficients = null      // path -> Phase 3 (incorporate federated coefficients)

    // Output
    outdir       = "results"
    publish_mode = "copy"

    // Model / reproducibility
    seed        = 42
    ridge_alpha = 1.0
    lasso_alpha = 0.008
    n_trees     = 200

    // Phase 3 — incorporating the central federated vector (applied as-is)
    federated_method = null    // ridge|lasso (default: read from the vector)
    n_boot           = 2000    // bootstrap resamples for the R² 95% CI

    // Shared container (built from container/oadr-cpep/, published to a registry)
    container = "ghcr.io/nih-nlm/oadr-cpep:0.1.0"
}

docker {
    enabled = true
}

process {
    withLabel: oadr_cpep {
        container = params.container
    }
}
