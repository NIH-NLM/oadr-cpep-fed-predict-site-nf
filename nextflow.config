params {
    // --- required ---
    site  = null       // the study id, e.g. SDY524
    panel = "B"        // feature panel: A (legacy 9) or B (extended 12)

    // --- explicit data files (no directory, no glob) ---
    //   Panel A: tidy + cpeptide.  Panel B: aa + demo + cpeptide (+ arms + arm_subjects)
    tidy         = null   // SDY<n>_tidy.csv                 (Panel A)
    aa           = null   // aa_<n>.csv                      (Panel B)
    demo         = null   // demo_<n>.csv                    (Panel B)
    cpeptide     = null   // SDY<n>_cpeptide_auc_tidy.csv    (both panels)
    arms         = null   // SDY<n>_arm_or_cohort.txt        (Panel B, optional)
    arm_subjects = null   // SDY<n>_arm_2_subject.txt        (Panel B, optional)

    // --- fit on an external feature list (else the DAG chains select -> fit) ---
    features = null       // a feature-list CSV (e.g. the aggregator's consensus)

    // --- apply: the aggregator's federated vectors (presence -> apply, not select/fit) ---
    federated_ridge = null   // federated ridge vector CSV
    federated_lasso = null   // federated lasso vector CSV
    federated_rf    = null   // federated rf_union.pkl

    // --- output ---
    outdir       = "results"
    publish_mode = "copy"

    // --- model / reproducibility ---
    seed        = 42
    ridge_alpha = 1.0
    lasso_alpha = 0.008
    n_trees     = 200
    n_boot      = 2000     // bootstrap resamples for the R² 95% CI

    // --- shared container (the current published oadr-cpep package image) ---
    container = "ghcr.io/nih-nlm/oadr-cpep:latest"
}

docker {
    enabled    = true
    runOptions = '--platform linux/amd64 --pull always'   // always use the current published image
}

profiles {
    // Local test on a Mac: no container — run the `oadr-cpep` CLI from your conda env.
    //   conda env create -f environment.yml && conda activate oadr-cpep-nf
    //   nextflow run main.nf -profile local --site SDY524 --panel B --aa … --demo … …
    local { docker.enabled = false }
}

process {
    withLabel: oadr_cpep {
        container        = params.container
        containerOptions = '--entrypoint ""'   // clear the micromamba entrypoint so `oadr-cpep` runs
    }
}
